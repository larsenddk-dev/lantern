# Lantern environment variables — copy to .env and fill in your values.
# Real .env is gitignored; only .env.example is committed.
#
# Phase 2a: provider selection is now managed in Settings (persisted server-side
# in apps/api/data/lantern.db, which is gitignored). The vars below remain
# as the default fallback when no active provider is set in Settings.

# ---------------------------------------------------------------------------
# AI Provider — default fallback (overridden by Settings → active provider)
# ---------------------------------------------------------------------------
#
# These are used only when no active provider is configured in Settings.
# To configure providers at runtime, open Settings in the Lantern UI.
#
# Option A: OpenRouter free models (https://openrouter.ai — free tier available)
# LANTERN_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# LANTERN_OPENAI_API_KEY=sk-or-...
# LANTERN_MODEL=openai/gpt-4o-mini

# Option B: Google Gemini (free tier via OpenAI-compatible endpoint)
# LANTERN_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LANTERN_OPENAI_API_KEY=AIza...
# LANTERN_MODEL=gemini-2.0-flash

# Option C: Groq (fast free tier — llama, mixtral, etc.)
# LANTERN_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# LANTERN_OPENAI_API_KEY=gsk_...
# LANTERN_MODEL=llama-3.3-70b-versatile

# Option D: Mistral
# LANTERN_OPENAI_BASE_URL=https://api.mistral.ai/v1
# LANTERN_OPENAI_API_KEY=...
# LANTERN_MODEL=mistral-small-latest

# Option E: Cerebras
# LANTERN_OPENAI_BASE_URL=https://api.cerebras.ai/v1
# LANTERN_OPENAI_API_KEY=...
# LANTERN_MODEL=llama-4-scout-17b-16e-instruct

# Option F: Local Ollama (no key needed)
# LANTERN_OPENAI_BASE_URL=http://localhost:11434/v1
# LANTERN_OPENAI_API_KEY=ollama
# LANTERN_MODEL=llama3.2

# Active provider settings (used as fallback when no Settings provider is active):
LANTERN_OPENAI_BASE_URL=https://openrouter.ai/api/v1
LANTERN_OPENAI_API_KEY=
LANTERN_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
# SQLite database path (defaults to apps/api/data/lantern.db — gitignored)
# Override only if you need a custom location.
# LANTERN_DB_PATH=apps/api/data/lantern.db

# CORS origin of the web app
LANTERN_WEB_ORIGIN=http://localhost:3000

# Optional: web search for the Agent / Research (Tavily — https://tavily.com).
# Leave blank to disable; the agent's web_search tool reports "not configured".
LANTERN_TAVILY_API_KEY=

# Optional: read-only email (IMAP). Leave blank to disable the Email page.
# Lantern only READS — it never sends or modifies your mailbox. For Gmail/
# Outlook, use an app-specific password.
LANTERN_IMAP_HOST=
LANTERN_IMAP_PORT=993
LANTERN_IMAP_USER=
LANTERN_IMAP_PASSWORD=

# ---------------------------------------------------------------------------
# Web app (Next.js — NEXT_PUBLIC_ prefix exposes to browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_LANTERN_API_URL=http://localhost:8000
