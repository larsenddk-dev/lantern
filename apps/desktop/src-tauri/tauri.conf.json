{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lantern",
  "version": "1.0.0",
  "identifier": "com.lantern.app",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lantern",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": [
      "sidecar/lantern-api/**/*",
      "sidecar/ollama/**/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
