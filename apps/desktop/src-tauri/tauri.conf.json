{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lantern",
  "version": "1.0.0",
  "identifier": "com.lantern.app",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lantern",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis",
      "appimage",
      "deb"
    ],
    "publisher": "Lantern",
    "copyright": "© 2026 Lantern — PolyForm Strict License 1.0.0",
    "category": "Productivity",
    "shortDescription": "Your own local-first AI workspace.",
    "longDescription": "Lantern is a local-first personal AI workspace — chat, agents, deep research, documents, notes, tasks and memory — running on your own hardware with your provider API keys or local models. Carry your own light.",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": [
      "sidecar/lantern-api/**/*"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installMode": "currentUser",
        "compression": "lzma"
      }
    },
    "licenseFile": "installer/LICENSE.txt"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}